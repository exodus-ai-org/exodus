{
  "name": "exodus",
  "version": "1.12.1",
  "description": "ChatBot featuring MCP, Immersive Editor, RAG, AI Agents, Deep Research, and other modern capabilities.",
  "homepage": "https://exdous.yancey.app",
  "author": "Yancey Leo",
  "main": "./out/main/index.js",
  "scripts": {
    "asar:sniff": "npx tsx scripts/asar-sniff.ts",
    "build": "npm run typecheck && electron-vite build",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "db:generate": "npx drizzle-kit generate",
    "dev": "electron-vite dev --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "postinstall": "electron-builder install-app-deps",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:electron": "playwright test --project=e2e",
    "test:e2e:providers": "playwright test --project=providers",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false"
  },
